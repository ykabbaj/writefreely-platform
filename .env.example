# WriteFreely source tag to build into the custom app image.
WRITEFREELY_VERSION=0.16.0

# Use https://localhost for local testing. For production, set both values to
# your public domain, for example:
# CADDY_SITE_ADDRESS=blog.example.com
# WRITEFREELY_HOST=https://blog.example.com
CADDY_SITE_ADDRESS=https://localhost
WRITEFREELY_HOST=https://localhost

# Host ports bound by Caddy.
HTTP_PORT=80
HTTPS_PORT=443

# Public site name and first admin account.
WRITEFREELY_SITE_NAME=MyBlog
WRITEFREELY_ADMIN_USER=owner
WRITEFREELY_ADMIN_PASSWORD=change-this-password

# Registration and publishing behavior.
WRITEFREELY_OPEN_REGISTRATION=false
WRITEFREELY_SINGLE_USER=false
WRITEFREELY_FEDERATION=false
WRITEFREELY_PUBLIC_STATS=false

# MySQL credentials. Change all passwords before public use.
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=writefreely
MYSQL_USER=writefreely
MYSQL_PASSWORD=change-this-db-password

# Compose uses the bundled db service by default.
WRITEFREELY_DB_HOST=
